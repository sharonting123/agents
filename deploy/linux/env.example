# 复制为 .env 或写入 systemd EnvironmentFile（需自行 export / source）
# 路径按你服务器实际修改

# 代码目录（可选；不设则自动用 config/ 的上一级）
# export CODE_BASE_DIR=/opt/procurement-assistant/Code

# ChatGLM2 基座（必须存在）
export LLM_MODEL_DIR=/opt/models/chatglm2-6b

# P-Tuning 权重（默认相对 Code/ptuning/...，与 Windows 目录结构一致时可不设）
# export CLASSIFY_CHECKPOINT_PATH=/opt/procurement-assistant/Code/ptuning/CLASSIFY_PTUNING/output/.../checkpoint-10
# export NL2SQL_CHECKPOINT_PATH=...
# export KEYWORDS_CHECKPOINT_PATH=...

# text2vec（F 类检索重排）；不设则 Linux 下默认 Code/models/text2vec-base-chinese
# export TEXT2VEC_MODEL_DIR=/opt/models/text2vec-base-chinese

# 显存与精度（12GB 建议保持）
export QA_MODEL_DEVICE_SPLIT=1
export QA_CHATGLM_FP16=1
# 基座 bitsandbytes 量化（CUDA；pip install bitsandbytes），省显存；4bit 与 8bit 二选一，同时设时优先 4bit
# export CHATGLM_LOAD_IN_4BIT=1
# export CHATGLM_LOAD_IN_8BIT=1
# 底座默认 cuda（与 cfg 一致）；仅当 GPU OOM 且内存极大时再改为 cpu
export QA_CHATGLM_DEVICE=cuda
# export QA_CHATGLM_DEVICE=cpu

# GPU 序号（与 qa_fastapi.py --gpu 一致）
export CUDA_VISIBLE_DEVICES=0

# MySQL（NL2SQL 执行）
export MYSQL_HOST=127.0.0.1
export MYSQL_PORT=3306
export MYSQL_USER=your_user
export MYSQL_PASSWORD=your_password
export MYSQL_DATABASE=bidding

# F 类 DeepSeek 补充（可选）
# export DEEPSEEK_API_KEY=你的密钥
